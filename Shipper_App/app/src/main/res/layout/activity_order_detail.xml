<?xml version="1.0" encoding="utf-8"?>
<!-- activity_order_detail.xml - Màn hình chi tiết đơn hàng -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/color_background">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/color_surface"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:elevation="2dp">

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:contentDescription="Quay lại"
            app:tint="@color/color_primary" />

        <!-- Order Code -->
        <TextView
            android:id="@+id/tv_order_code"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Đơn hàng #892A4"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:layout_marginStart="8dp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <!-- ===== STATUS CARD ===== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/color_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <!-- Status Label + Express Badge -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TRẠNG THÁI HIỆN TẠI"
                            android:textSize="11sp"
                            android:textColor="@color/color_text_secondary"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tv_express_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Express"
                            android:textSize="12sp"
                            android:textColor="@color/color_text_white"
                            android:textStyle="bold"
                            android:background="@drawable/bg_badge_primary"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"
                            android:visibility="visible" />
                    </LinearLayout>

                    <!-- Current Status Text -->
                    <TextView
                        android:id="@+id/tv_current_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đang lấy hàng"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="6dp" />

                    <!-- Ready Status Note -->
                    <TextView
                        android:id="@+id/tv_ready_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Có thể đến lấy hàng"
                        android:textSize="14sp"
                        android:textStyle="italic"
                        android:textColor="@color/color_primary"
                        android:layout_marginTop="4dp"
                        android:visibility="gone" />

                    <!-- Time Info -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🕐"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tv_received_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" Nhận lúc 14:20 · Ước tính giao 15:45"
                            android:textSize="13sp"
                            android:textColor="@color/color_text_secondary"
                            android:layout_marginStart="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== ROUTE CARD ===== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="4dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/color_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Section Title -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Lộ trình"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_text_primary"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tv_distance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 km"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_primary" />
                    </LinearLayout>

                    <!-- Pickup Point -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top">

                        <!-- Left icons column -->
                        <LinearLayout
                            android:layout_width="24dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:layout_marginEnd="12dp">

                            <!-- Pickup icon circle -->
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_location"
                                android:contentDescription="Điểm lấy hàng"
                                app:tint="@color/color_text_secondary" />

                            <!-- Dashed line connector -->
                            <View
                                android:layout_width="2dp"
                                android:layout_height="30dp"
                                android:background="@color/color_divider"
                                android:layout_marginTop="2dp"
                                android:layout_marginBottom="2dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ĐIỂM LẤY HÀNG"
                                android:textSize="11sp"
                                android:textColor="@color/color_text_secondary"
                                android:textAllCaps="true"
                                android:letterSpacing="0.05"
                                android:layout_marginBottom="3dp" />

                            <TextView
                                android:id="@+id/tv_pickup_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Cửa hàng Điện máy Xanh"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/color_text_primary"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginBottom="2dp" />

                            <TextView
                                android:id="@+id/tv_pickup_address"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="123 Nguyễn Văn Linh, Quận 7, TP. HCM"
                                android:textSize="13sp"
                                android:textColor="@color/color_text_secondary"
                                android:maxLines="2"
                                android:ellipsize="end" />
                        </LinearLayout>

                        <!-- Message Restaurant Button -->
                        <ImageButton
                            android:id="@+id/btn_message_restaurant"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_action_btn"
                            android:src="@drawable/ic_chat"
                            android:contentDescription="Nhắn tin nhà hàng"
                            android:layout_marginStart="8dp"
                            android:layout_gravity="center_vertical"
                            app:tint="@color/color_primary" />
                    </LinearLayout>

                    <!-- Delivery Point -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top">

                        <!-- Delivery icon -->
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_location_home"
                            android:contentDescription="Điểm giao hàng"
                            android:layout_marginEnd="12dp"
                            app:tint="@color/color_primary" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ĐIỂM GIAO HÀNG"
                                android:textSize="11sp"
                                android:textColor="@color/color_text_secondary"
                                android:textAllCaps="true"
                                android:letterSpacing="0.05"
                                android:layout_marginBottom="3dp" />

                            <TextView
                                android:id="@+id/tv_delivery_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Chung cư Sunrise City"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/color_text_primary"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginBottom="2dp" />

                            <TextView
                                android:id="@+id/tv_delivery_address"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="23 Nguyễn Hữu Thọ, Tân Hưng, Quận 7, TP. HCM"
                                android:textSize="13sp"
                                android:textColor="@color/color_text_secondary"
                                android:maxLines="2"
                                android:ellipsize="end" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== CUSTOMER CARD ===== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="4dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/color_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Section Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Khách hàng"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="12dp" />

                    <!-- Customer Info Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Avatar -->
                        <FrameLayout
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:background="@drawable/bg_avatar">
                            <TextView
                                android:id="@+id/tv_customer_initial"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="T"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/color_text_white"
                                android:gravity="center"
                                android:fontFamily="sans-serif-medium" />
                        </FrameLayout>

                        <!-- Name + Phone -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/tv_customer_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Trần Anh Tuấn"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/color_text_primary"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tv_customer_phone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="090 123 4567"
                                android:textSize="13sp"
                                android:textColor="@color/color_text_secondary"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <!-- Call Button -->
                        <ImageButton
                            android:id="@+id/btn_call_customer"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_action_btn"
                            android:src="@drawable/ic_phone"
                            android:contentDescription="Gọi điện"
                            android:layout_marginEnd="8dp"
                            app:tint="@color/color_primary" />

                        <!-- Message Button -->
                        <ImageButton
                            android:id="@+id/btn_message_customer"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_action_btn"
                            android:src="@drawable/ic_chat"
                            android:contentDescription="Nhắn tin"
                            app:tint="@color/color_primary" />
                    </LinearLayout>

                    <!-- Customer Note -->
                    <LinearLayout
                        android:id="@+id/layout_note"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_note"
                        android:padding="12dp"
                        android:layout_marginTop="12dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="5dp">
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginEnd="4dp"
                                android:src="@drawable/ic_note"
                                app:tint="@color/color_primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ghi chú"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/color_primary" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_customer_note"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="&quot;Gọi trước 5 phút khi đến. Giao cho bảo vệ tòa nhà V2 nếu tôi không nghe máy.&quot;"
                            android:textSize="13sp"
                            android:textColor="@color/color_text_secondary"
                            android:fontFamily="sans-serif"
                            android:lineSpacingExtra="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== ITEMS CARD ===== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="4dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/color_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/layout_items_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Danh sách món ăn"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_text_primary"
                            android:fontFamily="sans-serif-medium" />

                        <ImageView
                            android:id="@+id/iv_items_expand"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_arrow_down"
                            app:tint="@color/color_text_secondary" />
                    </LinearLayout>

                    <!-- Container for items added programmatically -->
                    <LinearLayout
                        android:id="@+id/layout_items_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:orientation="vertical" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== PAYMENT CARD ===== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/color_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thanh toán"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="14dp" />

                    <!-- Pending (COD) Layout -->
                    <LinearLayout
                        android:id="@+id/layout_payment_pending"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/layout_cod_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="?attr/selectableItemBackground"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Tiền thu hộ (COD)"
                                android:textSize="14sp"
                                android:textColor="@color/color_text_secondary" />

                            <TextView
                                android:id="@+id/tv_cod_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="850.000 đ"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/color_text_primary"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginEnd="8dp" />

                            <ImageView
                                android:id="@+id/iv_cod_expand"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:src="@drawable/ic_arrow_down"
                                app:tint="@color/color_text_secondary" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layout_cod_details"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone"
                            android:layout_marginTop="12dp">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/color_divider"
                                android:layout_marginBottom="8dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Tiền món ăn"
                                    android:textSize="14sp"
                                    android:textColor="@color/color_text_secondary" />
                                <TextView
                                    android:id="@+id/tv_food_amount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 đ"
                                    android:textSize="14sp"
                                    android:textColor="@color/color_text_primary" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Phí ship (khách trả)"
                                    android:textSize="14sp"
                                    android:textColor="@color/color_text_secondary" />
                                <TextView
                                    android:id="@+id/tv_ship_fee_customer"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 đ"
                                    android:textSize="14sp"
                                    android:textColor="@color/color_text_primary" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Phí ship (thực nhận)"
                                    android:textSize="14sp"
                                    android:textColor="@color/color_text_secondary" />
                                <TextView
                                    android:id="@+id/tv_ship_fee_detail"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 đ"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/color_online" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Giảm giá"
                                    android:textSize="14sp"
                                    android:textColor="@color/color_text_secondary" />
                                <TextView
                                    android:id="@+id/tv_discount_amount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 đ"
                                    android:textSize="14sp"
                                    android:textColor="@color/color_text_primary" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Paid Layout -->
                    <LinearLayout
                        android:id="@+id/layout_payment_paid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Đã thanh toán"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_online"
                            android:gravity="center"
                            android:layout_marginBottom="12dp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/color_divider"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Phí ship được nhận"
                                android:textSize="14sp"
                                android:textColor="@color/color_text_secondary" />

                            <TextView
                                android:id="@+id/tv_ship_fee_earned"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="25.000 đ"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/color_text_primary"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- ===== BOTTOM ACTION BAR ===== -->
    <LinearLayout
        android:id="@+id/layout_bottom_action"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/color_surface"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="8dp">

        <!-- Report Problem Button -->
        <ImageButton
            android:id="@+id/btn_report_problem"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_btn_warning"
            android:src="@android:drawable/ic_dialog_alert"
            android:contentDescription="Báo cáo sự cố"
            android:layout_marginEnd="12dp"
            app:tint="@color/color_warning" />

        <!-- Main Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_main_action"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Đã lấy hàng"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_white"
            app:backgroundTint="@color/color_primary"
            app:cornerRadius="12dp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>
</LinearLayout>
