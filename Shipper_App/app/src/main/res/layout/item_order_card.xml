<?xml version="1.0" encoding="utf-8"?>
<!-- item_order_card.xml - Item cho mỗi đơn hàng trong danh sách -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/color_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Row 1: Distance + Price -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- Distance Chip -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_distance_chip"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <!-- Route icon (roads/swap) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⇅"
                    android:textSize="14sp"
                    android:textColor="@color/color_primary"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tv_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.4 km"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_primary"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Ready Status Note -->
            <TextView
                android:id="@+id/tv_ready_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Có thể đến lấy hàng"
                android:textSize="12sp"
                android:textStyle="italic"
                android:textColor="@color/color_primary"
                android:layout_marginStart="8dp"
                android:visibility="gone" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Ship Fee -->
            <TextView
                android:id="@+id/tv_ship_fee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="45.000đ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_divider"
            android:layout_marginBottom="12dp" />

        <!-- Route Timeline -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/dot_pickup"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_dot_pickup"
                android:layout_marginTop="5dp"
                app:layout_constraintTop_toTopOf="@+id/layout_pickup"
                app:layout_constraintStart_toStartOf="parent" />

            <View
                android:id="@+id/line_timeline"
                android:layout_width="1dp"
                android:layout_height="0dp"
                android:background="@color/color_divider"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                app:layout_constraintTop_toBottomOf="@id/dot_pickup"
                app:layout_constraintBottom_toTopOf="@+id/dot_delivery"
                app:layout_constraintStart_toStartOf="@+id/dot_pickup"
                app:layout_constraintEnd_toEndOf="@+id/dot_pickup" />

            <View
                android:id="@+id/dot_delivery"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_dot_delivery"
                android:layout_marginTop="5dp"
                app:layout_constraintTop_toTopOf="@+id/layout_delivery"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:id="@+id/layout_pickup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/dot_pickup"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LẤY HÀNG"
                    android:textSize="11sp"
                    android:textColor="@color/color_text_secondary"
                    android:letterSpacing="0.05"
                    android:textAllCaps="true"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tv_pickup_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="123 Nguyễn Đình Chiểu, Quận 3"
                    android:textSize="14sp"
                    android:textColor="@color/color_text_primary"
                    android:fontFamily="sans-serif"
                    android:layout_marginBottom="12dp"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_delivery"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                app:layout_constraintTop_toBottomOf="@id/layout_pickup"
                app:layout_constraintStart_toEndOf="@id/dot_delivery"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GIAO ĐẾN"
                    android:textSize="11sp"
                    android:textColor="@color/color_text_secondary"
                    android:letterSpacing="0.05"
                    android:textAllCaps="true"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tv_delivery_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="456 Lê Lợi, Quận 1"
                    android:textSize="14sp"
                    android:textColor="@color/color_text_primary"
                    android:fontFamily="sans-serif"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Accept Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_accept_order"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Nhận đơn"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_white"
            app:backgroundTint="@color/color_primary"
            app:cornerRadius="10dp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
