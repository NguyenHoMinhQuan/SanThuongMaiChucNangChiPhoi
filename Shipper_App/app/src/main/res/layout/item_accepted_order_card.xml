<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/color_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Row 1: Status + Distance + Price (ConstraintLayout to prevent overlap and wrap badges) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            
            <com.google.android.material.chip.ChipGroup
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp"
                app:singleLine="false"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tv_ship_fee"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="12dp">
                
                <TextView
                    android:id="@+id/tv_order_status_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đang lấy hàng"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_primary"
                    android:background="@drawable/bg_distance_chip"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />
                    
                <TextView
                    android:id="@+id/tv_order_ready_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Món đã chuẩn bị xong"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_btn_primary"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:visibility="gone" />
            </com.google.android.material.chip.ChipGroup>

            <TextView
                android:id="@+id/tv_ship_fee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="45.000đ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_divider"
            android:layout_marginBottom="12dp" />

        <!-- Route Timeline -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/dot_pickup"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_dot_pickup"
                android:layout_marginTop="5dp"
                app:layout_constraintTop_toTopOf="@+id/layout_pickup"
                app:layout_constraintStart_toStartOf="parent" />

            <View
                android:id="@+id/line_timeline"
                android:layout_width="1dp"
                android:layout_height="0dp"
                android:background="@color/color_divider"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                app:layout_constraintTop_toBottomOf="@id/dot_pickup"
                app:layout_constraintBottom_toTopOf="@+id/dot_delivery"
                app:layout_constraintStart_toStartOf="@+id/dot_pickup"
                app:layout_constraintEnd_toEndOf="@+id/dot_pickup" />

            <View
                android:id="@+id/dot_delivery"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_dot_delivery"
                android:layout_marginTop="5dp"
                app:layout_constraintTop_toTopOf="@+id/layout_delivery"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:id="@+id/layout_pickup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/dot_pickup"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LẤY HÀNG"
                    android:textSize="11sp"
                    android:textColor="@color/color_text_secondary"
                    android:letterSpacing="0.05"
                    android:textAllCaps="true"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tv_pickup_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="123 Nguyễn Đình Chiểu, Quận 3"
                    android:textSize="14sp"
                    android:textColor="@color/color_text_primary"
                    android:fontFamily="sans-serif"
                    android:layout_marginBottom="12dp"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_delivery"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                app:layout_constraintTop_toBottomOf="@id/layout_pickup"
                app:layout_constraintStart_toEndOf="@id/dot_delivery"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GIAO ĐẾN"
                    android:textSize="11sp"
                    android:textColor="@color/color_text_secondary"
                    android:letterSpacing="0.05"
                    android:textAllCaps="true"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tv_delivery_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="456 Lê Lợi, Quận 1"
                    android:textSize="14sp"
                    android:textColor="@color/color_text_primary"
                    android:fontFamily="sans-serif"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Cancel Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_order"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Hủy giao hàng"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#D32F2F"
            app:backgroundTint="#FFEBEE"
            app:cornerRadius="10dp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
