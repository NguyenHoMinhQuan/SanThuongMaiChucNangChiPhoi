<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".StatisticsActivity">

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F8F9FA">

        <!-- Custom Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@android:color/white"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            android:elevation="2dp">

            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_menu"
                android:contentDescription="Menu"
                app:tint="@color/color_primary" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thống kê thu nhập"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Theo dõi hiệu suất và doanh thu của bạn."
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp" />

                <!-- Tabs -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_search_box"
                    android:padding="2dp"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:id="@+id/tab_today"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Hôm nay"
                        android:gravity="center"
                        android:textSize="13sp"
                        android:textColor="#757575"
                        android:background="@null" />

                    <TextView
                        android:id="@+id/tab_week"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Tuần này"
                        android:gravity="center"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:background="@drawable/bg_white_rounded" />

                    <TextView
                        android:id="@+id/tab_month"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Tháng này"
                        android:gravity="center"
                        android:textSize="13sp"
                        android:textColor="#757575" />
                </LinearLayout>

                <!-- Summary Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@android:color/white"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:id="@+id/tv_earnings_title"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Tổng thu nhập tuần này"
                                android:textSize="13sp"
                                android:textColor="#757575" />
                            <ImageView
                                android:id="@+id/iv_visibility"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_visibility"
                                app:tint="@color/color_primary" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_total_earnings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0đ"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="20dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:id="@+id/tv_target_label"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Tiến độ mục tiêu (5.000.000đ)"
                                android:textSize="11sp"
                                android:textColor="#757575" />
                            <TextView
                                android:id="@+id/tv_target_progress"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/color_primary" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/progress_target"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="6dp"
                            android:max="100"
                            android:progress="65"
                            android:progressDrawable="@drawable/bg_progress_horizontal" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Chart Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@android:color/white"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Biểu đồ doanh thu"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:layout_marginBottom="8dp" />

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/line_chart"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Stats Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="24dp">
                    
                    <!-- Row 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_stat_card"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp"
                            android:gravity="center_vertical">
                            
                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_circle_purple"
                                android:layout_marginEnd="12dp">
                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_order_approve"
                                    app:tint="#5E67D2" />
                            </FrameLayout>
                            
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Đơn hoàn\nthành"
                                    android:textSize="12sp"
                                    android:textColor="#757575" />
                                <TextView
                                    android:id="@+id/tv_completed_orders"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="#1A1A1A" />
                            </LinearLayout>
                        </LinearLayout>
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_stat_card"
                            android:padding="12dp"
                            android:layout_marginStart="6dp"
                            android:gravity="center_vertical">
                            
                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_circle_red"
                                android:layout_marginEnd="12dp">
                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@android:drawable/ic_delete"
                                    app:tint="#D32F2F" />
                            </FrameLayout>
                            
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Đơn hủy"
                                    android:textSize="12sp"
                                    android:textColor="#757575" />
                                <TextView
                                    android:id="@+id/tv_cancelled_orders"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="#1A1A1A" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                    
                    <!-- Row 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_stat_card"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp"
                            android:gravity="center_vertical">
                            
                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_circle_green"
                                android:layout_marginEnd="12dp">
                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@android:drawable/ic_menu_recent_history"
                                    app:tint="#FF6600" />
                            </FrameLayout>
                            
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Giờ hoạt động"
                                    android:textSize="12sp"
                                    android:textColor="#757575" />
                                <TextView
                                    android:id="@+id/tv_active_hours"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0h"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="#1A1A1A" />
                            </LinearLayout>
                        </LinearLayout>
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_stat_card"
                            android:padding="12dp"
                            android:layout_marginStart="6dp"
                            android:gravity="center_vertical">
                            
                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_circle_blue"
                                android:layout_marginEnd="12dp">
                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@android:drawable/star_on"
                                    app:tint="#1976D2" />
                            </FrameLayout>
                            
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Đánh giá TB"
                                    android:textSize="12sp"
                                    android:textColor="#757575" />
                                <TextView
                                    android:id="@+id/tv_rating_avg"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0.0"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="#1A1A1A" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Order History -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Lịch sử đơn hàng"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#1A1A1A" />
                    <TextView
                        android:id="@+id/tv_view_all_orders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xem tất cả"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="@color/color_primary" />
                </LinearLayout>

                <!-- Orders container to be populated dynamically -->
                <LinearLayout
                    android:id="@+id/ll_order_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/color_surface"
        app:itemTextColor="@color/nav_item_color"
        app:itemIconTint="@color/nav_item_color"
        app:itemBackground="@drawable/nav_item_background"
        app:headerLayout="@layout/nav_header_main"
        app:menu="@menu/activity_main_drawer"
        app:itemTextAppearance="?android:attr/textAppearanceMedium" />

</androidx.drawerlayout.widget.DrawerLayout>
