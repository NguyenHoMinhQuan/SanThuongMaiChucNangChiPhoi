<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Quyền gọi điện -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <!-- Quyền gửi SMS -->
    <uses-permission android:name="android.permission.SEND_SMS" />
    <!-- Quyền truy cập Internet (cho API sau này) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Quyền truy cập vị trí (cho tính khoảng cách) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Shipper_App">

        <!-- Màn hình khởi động -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Shipper_App">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Shipper_App" />

        <activity
            android:name=".NotificationActivity"
            android:exported="false"
            android:theme="@style/Theme.Shipper_App" />

        <!-- Màn hình danh sách đơn hàng (Home) -->
        <activity
            android:name=".HomeActivity"
            android:exported="false"
            android:label="Đơn hàng"
            android:theme="@style/Theme.Shipper_App" />

        <!-- Màn hình đăng nhập -->
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:label="Đăng nhập"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Shipper_App" />

        <!-- Màn hình chi tiết đơn hàng -->
        <activity
            android:name=".OrderDetailActivity"
            android:exported="false"
            android:label="Chi tiết đơn hàng"
            android:theme="@style/Theme.Shipper_App"
            android:parentActivityName=".HomeActivity">
            <!-- Hỗ trợ nút Back trên ActionBar -->
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".HomeActivity" />
        </activity>

        <!-- Màn hình Đơn đã nhận -->
        <activity
            android:name=".AcceptedOrdersActivity"
            android:exported="false"
            android:label="Đơn đã nhận"
            android:theme="@style/Theme.Shipper_App"
            android:parentActivityName=".HomeActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".HomeActivity" />
        </activity>

        <!-- Màn hình Thống kê -->
        <activity
            android:name=".StatisticsActivity"
            android:exported="false"
            android:label="Thống kê"
            android:theme="@style/Theme.Shipper_App"
            android:parentActivityName=".HomeActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".HomeActivity" />
        </activity>

        <!-- Màn hình Sự cố -->
        <activity
            android:name=".IssueActivity"
            android:exported="false"
            android:label="Sự cố"
            android:theme="@style/Theme.Shipper_App"
            android:parentActivityName=".HomeActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".HomeActivity" />
        </activity>

        <activity
            android:name=".ComplaintDetailActivity"
            android:exported="false"
            android:label="Chi tiết sự cố"
            android:theme="@style/Theme.Shipper_App" />

        <activity
            android:name=".CreateIssueActivity"
            android:exported="false"
            android:label="Gửi báo cáo sự cố"
            android:theme="@style/Theme.Shipper_App" />

        <activity
            android:name=".ProfileActivity"
            android:exported="false"
            android:label="Hồ sơ tài xế"
            android:theme="@style/Theme.Shipper_App" />

        <activity
            android:name=".ChatActivity"
            android:exported="false"
            android:label="Chat"
            android:theme="@style/Theme.Shipper_App"
            android:parentActivityName=".HomeActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".HomeActivity" />
        </activity>

        <activity
            android:name=".WalletActivity"
            android:exported="false"
            android:label="Ví thu nhập"
            android:theme="@style/Theme.Shipper_App" />

        <activity
            android:name=".ChatDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Shipper_App"
            android:windowSoftInputMode="adjustResize|stateHidden"
            android:parentActivityName=".ChatActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".ChatActivity" />
        </activity>

    </application>

</manifest>